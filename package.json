{
  "name": "@ansvar/it-quality-mcp",
  "version": "1.0.0",
  "description": "IT Quality MCP — ITIL 4, COBIT, ISO 20000, ISO 22301, CMMI, and SLA metrics via Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "it-quality-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data/database.db",
    "server.json"
  ],
  "scripts": {
    "build": "tsc",
    "build:db": "node --import tsx scripts/build-db.ts",
    "seed": "npm run build:db",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run __tests__/unit --passWithNoTests",
    "test:contract": "vitest run __tests__/contract --passWithNoTests",
    "validate": "npm run build && npm run test && npm run test:contract",
    "prepublishOnly": "npm run build",
    "postinstall": "test -d dist || npm run build || true"
  },
  "dependencies": {
    "@ansvar/mcp-sqlite": "^1.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ansvar-Systems/it-quality-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Ansvar-Systems/it-quality-mcp/issues"
  },
  "homepage": "https://github.com/Ansvar-Systems/it-quality-mcp#readme",
  "keywords": [
    "mcp",
    "itil",
    "cobit",
    "itsm",
    "iso20000",
    "iso22301",
    "cmmi",
    "it-governance",
    "sla"
  ],
  "author": "Ansvar Systems AB <hello@ansvar.ai>",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "eu.ansvar/it-quality-mcp"
}
